# See also ../.env.example (full-stack). Copy to .env and fill in values.

DATABASE_URL=postgresql+asyncpg://user:password@host:5432/futurus
REDIS_URL=redis://localhost:6379/0

CLERK_SECRET_KEY=sk_live_REPLACE_WITH_YOUR_CLERK_SECRET_KEY
# SECURITY: Clerk session JWT audience (required when ENVIRONMENT=production)
CLERK_JWT_AUDIENCE=https://futurus.dev

LLM_API_KEY=REPLACE_WITH_YOUR_OPENAI_OR_QWEN_KEY
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_TIER1=gpt-4o
LLM_MODEL_TIER2=gpt-4o-mini

ZEP_API_KEY=REPLACE_WITH_YOUR_ZEP_API_KEY

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=futurus-reports
AWS_CLOUDFRONT_URL=
AWS_SES_REGION=us-east-1

APP_DOMAIN=futurus.dev
BACKEND_URL=http://localhost:8000
MAX_COST_PER_SIMULATION_USD=5.00

# development | production
ENVIRONMENT=development

# true = run simulations in a background thread with uvicorn only (recommended local dev).
# false = enqueue Celery — you MUST run: celery -A workers.celery_app worker -l info
FUTURUS_SIMULATION_WORKER_INLINE=true
