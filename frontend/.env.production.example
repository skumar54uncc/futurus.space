# FastAPI base URL (no trailing slash). On DigitalOcean App Platform, use https://your-api.ondigitalocean.app
NEXT_PUBLIC_SITE_URL=https://futurus.dev
NEXT_PUBLIC_BACKEND_URL=https://api.futurus.dev
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Preferred (Clerk v5); remove legacy NEXT_PUBLIC_CLERK_AFTER_SIGN_* from Vercel if set
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/new
# Set true only after enabling Analytics + Speed Insights in the Vercel project (avoids 404 console noise)
NEXT_PUBLIC_ENABLE_VERCEL_ANALYTICS=false
