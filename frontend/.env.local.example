# Public site URL (no trailing slash) — Clerk logo URL and OAuth redirects; Vercel sets VERCEL_URL if omitted
NEXT_PUBLIC_SITE_URL=http://localhost:3000

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/new
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Contact form (Gmail example: use an App Password, not your normal password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=youraddress@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=youraddress@gmail.com
# CONTACT_TO_EMAIL=youraddress@gmail.com
