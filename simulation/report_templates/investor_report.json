    {"id": "risks", "title": "Key Risks & Mitigations", "type": "table", "data_key": "risk_matrix", "max_items": 5},
    {"id": "competitive_moat", "title": "Competitive Position", "type": "text", "prompt": "Based on simulation, describe defensibility."},
    {"id": "recommendation", "title": "Investment Recommendation", "type": "text", "prompt": "Clear recommendation with confidence level."}
