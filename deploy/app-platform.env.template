# Futurus — DigitalOcean App Platform (bulk env editor)
# ------------------------------------------------------------
# Copy locally, fill REPLACE_* values, DELETE all # lines, then paste into DO.
# REDIS_URL: URI only — rediss://default:TOKEN@HOST:6379 — NOT "redis-cli --tls -u ..."
# DATABASE_URL: postgresql://... is OK (app adds +asyncpg). Add ?sslmode=require for Supabase.
# CLERK_JWT_AUDIENCE: JWT aud URL — NOT pk_test / publishable key.
# ------------------------------------------------------------

DATABASE_URL=REPLACE_POSTGRESQL_URI_FROM_SUPABASE
REDIS_URL=REPLACE_REDISS_OR_REDIS_URI_FROM_UPSTASH_TCP_TAB

CLERK_SECRET_KEY=REPLACE_CLERK_SECRET_KEY
CLERK_JWT_AUDIENCE=REPLACE_CLERK_JWT_AUDIENCE

ZEP_API_KEY=REPLACE_ZEP_API_KEY

MODEL_ACCESS_KEY=REPLACE_DO_MODEL_ACCESS_KEY
LLM_API_KEY=REPLACE_SAME_AS_MODEL_ACCESS_KEY
LLM_BASE_URL=https://inference.do-ai.run/v1
LLM_MODEL_TIER1=alibaba-qwen3-32b
LLM_MODEL_TIER2=alibaba-qwen3-32b

ENVIRONMENT=production
BACKEND_URL=https://REPLACE_AFTER_DEPLOY.ondigitalocean.app
APP_DOMAIN=REPLACE_VERCEL_HOSTNAME.vercel.app
MAX_COST_PER_SIMULATION_USD=5
FUTURUS_SIMULATION_WORKER_INLINE=true
