# Futurus — DigitalOcean App Platform (bulk env editor)
# ------------------------------------------------------------
# Copy locally, fill REPLACE_* values, DELETE all # lines, then paste into DO.
# REDIS_URL: URI only — rediss://default:TOKEN@HOST:6379 — NOT "redis-cli --tls -u ..."
# DATABASE_URL: postgresql://... is OK (app adds +asyncpg). Add ?sslmode=require for Supabase.
# CLERK_JWT_AUDIENCE: JWT aud URL — NOT pk_test / publishable key.
# ------------------------------------------------------------

# Prefer Supabase transaction pooler :6543?pgbouncer=true (not direct :5432) for serverless/PaaS.
DATABASE_URL=REPLACE_POSTGRESQL_URI_FROM_SUPABASE
REDIS_URL=REPLACE_REDISS_OR_REDIS_URI_FROM_UPSTASH_TCP_TAB
# HTTP REST (same Upstash DB) — distributed LLM counters without extra TCP connections:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Optional: cap asyncio Redis pool (WebSocket / health / idempotency). Default 8.
REDIS_MAX_CONNECTIONS=8

CLERK_SECRET_KEY=REPLACE_CLERK_SECRET_KEY
CLERK_JWT_AUDIENCE=REPLACE_CLERK_JWT_AUDIENCE

ZEP_API_KEY=REPLACE_ZEP_API_KEY

MODEL_ACCESS_KEY=REPLACE_DO_MODEL_ACCESS_KEY
LLM_API_KEY=REPLACE_SAME_AS_MODEL_ACCESS_KEY
# Base URL without path — app posts to …/v1/chat/completions and sends max_completion_tokens (DO requirement).
LLM_BASE_URL=https://inference.do-ai.run/v1
LLM_MODEL_TIER1=alibaba-qwen3-32b
LLM_MODEL_TIER2=alibaba-qwen3-32b
# Optional fallback when DO inference errors: GROQ_API_KEYS=gsk_abc,gsk_def (comma-separated)

ENVIRONMENT=production
SENTRY_DSN=
ADMIN_EMAIL=
BACKEND_URL=https://REPLACE_AFTER_DEPLOY.ondigitalocean.app
APP_DOMAIN=REPLACE_VERCEL_HOSTNAME.vercel.app
# Simulation “Email updates” sends mail from the **backend** when the run completes — not from Vercel.
# Option A: AWS SES (verify domain / sender in SES). Option B: Gmail (same vars as contact form):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=youraccount@gmail.com
# SMTP_PASS=<16-char Google App Password>
# SMTP_FROM=Futurus <youraccount@gmail.com>
MAX_COST_PER_SIMULATION_USD=5
FUTURUS_SIMULATION_WORKER_INLINE=true

# Rate limits: omit the next line to use REDIS_URL (shared across multiple App Platform instances).
# Single instance only: FUTURUS_RATE_LIMIT_STORAGE_URI=memory avoids sync Redis hops per request.
# FUTURUS_RATE_LIMIT_STORAGE_URI=memory

# Optional tuning (defaults are safe for ~60s gateways): FUTURUS_IDEA_ANALYSIS_DEADLINE_SECONDS=52 FUTURUS_IDEA_ANALYSIS_READ_TIMEOUT=22

# Clerk: CLERK_SECRET_KEY must be from the SAME Clerk app as the frontend publishable key (both test or both live).
# Production Vercel: use pk_live_ / sk_live_ — dev keys on a public URL are a security and rate-limit risk.
# CLERK_JWT_AUDIENCE = Clerk Dashboard → API Keys → Frontend API URL (aud claim), not the publishable key string.
# Smoke test: GET https://YOUR_APP.ondigitalocean.app/health — Protected routes need POST + Authorization: Bearer (JWT from signed-in app); a bare browser URL will not be authenticated.
# DB: if `reports` predates the viability summary column, run deploy/add_report_viability_summary.sql once on Postgres (Supabase SQL editor).
