# Futurus — Google Cloud Run env (copy values into Console or gcloud --set-env-vars).
# Do NOT commit real secrets. Use Secret Manager for production keys.
# ------------------------------------------------------------
# Prefer Supabase pooler :6543?pgbouncer=true for Cloud Run.
# REDIS_URL: Upstash rediss://… (TCP). Optional Upstash REST for LLM counters.
# ------------------------------------------------------------

DATABASE_URL=REPLACE_POSTGRESQL_URI_FROM_SUPABASE
REDIS_URL=REPLACE_REDISS_URI_FROM_UPSTASH

CLERK_SECRET_KEY=REPLACE_CLERK_SECRET_KEY
CLERK_JWT_AUDIENCE=REPLACE_CLERK_JWT_AUDIENCE

FIREWORKS_API_KEY=REPLACE_FIREWORKS_API_KEY
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/models/deepseek-v4-flash
GROQ_API_KEYS=REPLACE_OPTIONAL_COMMA_SEPARATED_GROQ_KEYS
# Also accepted: GROQ_API_KEY=gsk_xxx (singular)

ZEP_API_KEY=REPLACE_OPTIONAL
TIMESFM_SERVICE_URL=REPLACE_HF_SPACE_URL
TAVILY_API_KEY=
SENTRY_DSN=

ENVIRONMENT=production
FUTURUS_SIMULATION_WORKER_INLINE=true
FUTURUS_RATE_LIMIT_STORAGE_URI=memory://
MAX_COST_PER_SIMULATION_USD=5
ADMIN_EMAIL=REPLACE_YOUR_EMAIL

# Set AFTER first deploy to the Cloud Run HTTPS URL:
BACKEND_URL=https://REPLACE.a.run.app
APP_DOMAIN=REPLACE_VERCEL_HOSTNAME.vercel.app
CORS_EXTRA_ORIGINS=https://REPLACE_VERCEL_HOSTNAME.vercel.app,https://futurus.dev,https://www.futurus.dev

SENTRY_DSN=
