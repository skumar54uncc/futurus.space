# Database
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/futurus

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth (Clerk)
CLERK_SECRET_KEY=sk_live_REPLACE_WITH_YOUR_CLERK_SECRET_KEY
# SECURITY: Session JWT audience from Clerk (Frontend API URL / authorized party)
CLERK_JWT_AUDIENCE=https://futurus.dev

# LLM
LLM_API_KEY=REPLACE_WITH_YOUR_OPENAI_OR_QWEN_KEY
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_TIER1=gpt-4o
LLM_MODEL_TIER2=gpt-4o-mini

# Zep (agent memory — MiroFish)
ZEP_API_KEY=REPLACE_WITH_YOUR_ZEP_API_KEY

# AWS (S3 + CloudFront + SES)
AWS_ACCESS_KEY_ID=REPLACE_WITH_YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_YOUR_AWS_SECRET_KEY
AWS_REGION=us-east-1
AWS_S3_BUCKET=futurus-reports
AWS_CLOUDFRONT_URL=https://REPLACE.cloudfront.net
AWS_SES_REGION=us-east-1

# Stripe (optional — webhooks not wired in this API yet)
STRIPE_SECRET_KEY=sk_live_REPLACE_WITH_YOUR_STRIPE_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET

# App
APP_DOMAIN=futurus.dev
BACKEND_URL=https://api.futurus.dev
NEXT_PUBLIC_BACKEND_URL=https://api.futurus.dev
MAX_COST_PER_SIMULATION_USD=5.00
# development | production (production enforces CLERK_JWT_AUDIENCE + stricter checks)
ENVIRONMENT=development

# Inline worker: True = run simulations in-process (good for local dev with uvicorn only).
# Set false when using a Celery worker + Redis.
FUTURUS_SIMULATION_WORKER_INLINE=true
